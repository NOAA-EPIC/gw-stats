#!/bin/bash

 if [ $# -ne 1 ]
 then
   xmlfiles=`ls *.xml`
   xmlitems=(${xmlfiles//./ })
   casename=${xmlitems[0]}
 else
   casename=$1
 fi

 /gpfs/csfs1/work/huangwei/src/gw-stats/bin/statme ${casename} > ${casename}.stats

 python /gpfs/csfs1/work/huangwei/src/gw-stats/bin/stat4atm.py --workdir . --filename ${casename}.stats > stats.${casename}


